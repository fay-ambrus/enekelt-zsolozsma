\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{gregosheet}[2025/01/01 Custom sheet music]

\newif\ifgregosheet@debug
\DeclareOption{debug}{\gregosheet@debugtrue}
\ProcessOptions\relax

\RequirePackage{fontspec}
\RequirePackage{luacode}
\RequirePackage{xparse}

% Load Lua module
\directlua{
  require("gregosheet/gregosheet.common")
  require("gregosheet/gregosheet.parser")
  require("gregosheet/gregosheet.spacing")
  require("gregosheet/gregosheet.render")
  require("gregosheet/gregosheet.main")
}

% Capture font IDs in Lua
\newfontfamily\MusicFont{GuidoHU.ttf}

% Debug
\newcommand{\gregosheetdebug}{\directlua{gregosheet.debug = true}}
\ifgregosheet@debug
  \gregosheetdebug
\fi

{\MusicFont\fontsize{20}{24}\selectfont
  \directlua{gregosheet.music_fontid = font.current()}
}

% ============================================================
% Sheet definitions
% ============================================================
\ExplSyntaxOn

\keys_define:nn { gregosheet/def } {
  tone .tl_set:N = \l_gregosheet_def_tone_tl,
  tone .initial:n = {},
}

\NewDocumentCommand{\defsheet}{O{} m m m}{
  \tl_clear:N \l_gregosheet_def_tone_tl
  \keys_set:nn { gregosheet/def } { #1 }
  \cs_gset:cpn {sheetmelody@#2} {#3}
  \cs_gset:cpn {sheetlyrics@#2} {#4}
  \cs_gset:cpx {sheettone@#2} { \tl_use:N \l_gregosheet_def_tone_tl }
}

% ============================================================
% Gregosheet environment
% ============================================================
\tl_new:N \g_gregosheet_pieces_tl
\tl_new:N \g_gregosheet_clef_tl

\keys_define:nn { gregosheet } {
  clef .tl_gset:N = \g_gregosheet_clef_tl,
}

\NewDocumentEnvironment{gregosheet}{O{}}{
  % begin
  \tl_gclear:N \g_gregosheet_pieces_tl
  \tl_gset:Nn \g_gregosheet_clef_tl {all}
  \keys_set:nn { gregosheet } { #1 }
  \vskip\blockvskip
  \catcode`\_=12
  \catcode`\^=12
  \catcode`\$=12
  {\lyricfont\fontsize{10}{12}\selectfont
    \directlua{gregosheet.lyrics_fontid = font.current()}
  }
}{
  % end: call Lua
  \directlua{
    gregosheet.main(
      { \tl_use:N \g_gregosheet_pieces_tl },
      "\luaescapestring{\tl_use:N \g_gregosheet_clef_tl}"
    )
  }
  \vskip\blockvskip
}

% ============================================================
% \addsheet[head={...}, sub={...}]{Name}
% ============================================================
\keys_define:nn { gregosheet/piece } {
  title .tl_set:N = \l_gregosheet_title_tl,
  title .initial:n = {},
  tone .tl_set:N = \l_gregosheet_piece_tone_tl,
  tone .initial:n = {},
}

\NewDocumentCommand{\addsheet}{O{} m}{
  \keys_set:nn { gregosheet/piece } { #1 }
  \cs_if_exist:cTF {sheetmelody@#2}
  {
    \tl_set:Nx \l_tmpa_tl { \cs_if_exist_use:c {sheettone@#2} }
    \__gregosheet_add_piece:eee
      { \use:c {sheetmelody@#2} }
      { \use:c {sheetlyrics@#2} }
      { \tl_use:N \l_tmpa_tl }
  }
  { \textbf{[Missing~sheet:~#2]} }
}

% ============================================================
% \addinline[head={...}, sub={...}]{melody}{lyrics}
% ============================================================
\NewDocumentCommand{\addinline}{O{} m m}{
  \keys_set:nn { gregosheet/piece } { #1 }
  \__gregosheet_add_piece:nnn { #2 } { #3 } { \tl_use:N \l_gregosheet_piece_tone_tl }
}

% ============================================================
% Internal: append a piece to the Lua table
% ============================================================
\cs_new:Nn \__gregosheet_add_piece:nnn {
  \tl_gput_right:Nx \g_gregosheet_pieces_tl {
    { melody = "\luaescapestring{ #1 }",
      lyrics = "\luaescapestring{ #2 }",
      tone = "\luaescapestring{ #3 }",
      title = "\luaescapestring{ \tl_use:N \l_gregosheet_title_tl }" },
  }
}
\cs_generate_variant:Nn \__gregosheet_add_piece:nnn { eee }

% ============================================================
% \addtext{text} - adds red inline text to lyrics stream
% ============================================================
\NewDocumentCommand{\addtext}{m}{
  \tl_gput_right:Nx \g_gregosheet_pieces_tl {
    { melody = "",
      lyrics = "<<#1>>",
      title = "" },
  }
}

% ============================================================
% \printsheet shorthand
% ============================================================
\NewDocumentCommand{\printsheet}{m}{
  \begin{gregosheet}
    \addsheet{#1}
  \end{gregosheet}
}

\ExplSyntaxOff
