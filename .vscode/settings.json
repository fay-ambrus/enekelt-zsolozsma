{
  "latex-workshop.latex.tools": [
    {
      "name": "lualatex",
      "command": "cmd",
      "args": [
        "/c",
        "set TEXINPUTS=%DIR%\\;%DIR%\\gregosheet\\;%DIR%\\gregosheet-psalm\\;&& set LUAINPUTS=%DIR%\\;%DIR%\\gregosheet\\;%DIR%\\gregosheet-psalm\\;&& cd /d %OUTDIR% && lualatex --shell-escape -interaction=nonstopmode -synctex=1 %DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "LuaLaTeX",
      "tools": ["lualatex"]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.outDir": "%DIR%/out"
}
